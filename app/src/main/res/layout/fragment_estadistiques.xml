<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DCD9D9"
    android:layout_marginBottom="10dp"
    tools:context=".FragmentEstadistiques">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="15dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estadístiques"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="22dp"
                android:layout_margin="15dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Municipis visitats"
                android:textStyle="bold"
                android:textSize="16dp"/>

            <TextView
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/munvisi"
                android:text="S'han visitat x municipis d'un total de 804."
                android:textSize="14dp"/>


            <androidx.cardview.widget.CardView
                xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="16dp"
                android:layout_marginHorizontal="2dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical">

                    <!-- Barra de progreso, centrada -->
                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="0dp"
                        android:layout_height="22dp"
                        android:layout_weight="1"
                        android:progressDrawable="@drawable/progress_bar_custom"
                        style="?android:attr/progressBarStyleHorizontal" />

                    <!-- Texto del porcentaje, con ancho fijo -->
                    <TextView
                        android:id="@+id/indicadorpercentatge"
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:paddingStart="4dp"
                        android:textSize="14sp"
                        android:textColor="#444444" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Distribució dels municipis visitats"
                android:textStyle="bold"
                android:layout_marginVertical="15dp"
                android:textSize="16dp"/>

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="360dp"
                android:layout_height="360dp"
                android:layout_marginBottom="15dp"
                android:layout_gravity="center"/>

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChartVegueria"
                android:layout_width="380dp"
                android:layout_height="380dp"
                android:layout_gravity="center"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Percentatge de municipis visitats per comarques"
                android:textStyle="bold"
                android:layout_marginTop="30dp"
                android:textSize="16dp"/>


            <ScrollView
                xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp"
                android:background="#00F8F8F8"
                android:padding="6dp">

                <LinearLayout
                    android:id="@+id/progress_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:spacing="8dp"/>
            </ScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Top 10 municipis més visitats"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="10dp"
                android:textSize="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Top 5 comarques més visitades"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="10dp"
                android:textSize="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Top 3 vegueries més visitades"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="10dp"
                android:textSize="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Top 3 províncies més visitades"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="70dp"
                android:textSize="16dp"/>







            <!--TextView
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Comarques de la província de Barcelona"
                android:layout_marginBottom="5dp"
                android:textSize="14dp"/>

            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/barChartB"
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="300dp"/>

            <TextView
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Comarques de la província de Girona"
                android:layout_marginBottom="5dp"
                android:textSize="14dp"/>

            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/barChartG"
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="300dp"/>

            <TextView
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Comarques de la província de Tarragona"
                android:layout_marginBottom="5dp"
                android:textSize="14dp"/>

            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/barChartT"
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="300dp"/>

            <TextView
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Comarques de la província de Lleida"
                android:layout_marginBottom="5dp"
                android:textSize="14dp"/>

            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/barChartL"
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="100dp"/-->
        </LinearLayout>
    </ScrollView>

</FrameLayout>
