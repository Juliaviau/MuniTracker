<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"

    android:gravity="center"
    android:clipToPadding="true">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    
    <TextView
        android:id="@+id/zonaNom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nom de la zona"
        android:fontFamily="casual"
        android:textSize="24sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:paddingBottom="10dp"
        android:gravity="center" />



    <TextView
        android:id="@+id/zonaIfnfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Visites anteriors"
        android:fontFamily="casual"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:paddingBottom="2dp"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:id="@+id/indicadorpercentatge"
            android:gravity="center"
            android:textSize="16dp"
            android:text="50%"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:progressDrawable="@drawable/progress_bar_progress"
            android:max="100"
            android:progress="0"
            android:layout_margin="16dp"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewS"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:visibility="visible"
        android:background="@drawable/rounded_background"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:clipToPadding="false"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/visitasContainerS"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:orientation="vertical"/>
    </androidx.core.widget.NestedScrollView>


    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/closeButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tornar al mapa"
        android:layout_gravity="center"
        android:background="@drawable/estilboto"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#D88479"
        android:textColor="@android:color/white"
        android:layout_marginTop="20dp"
        android:padding="6dp"
        android:paddingHorizontal="12dp" />

</LinearLayout>