<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/txtNomFila"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#222222"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="100dp"
        android:layout_height="14dp"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:weightSum="5">

        <View android:id="@+id/v1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <View android:id="@+id/v2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <View android:id="@+id/v3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <View android:id="@+id/v4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <View android:id="@+id/v5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
    </LinearLayout>
</LinearLayout>