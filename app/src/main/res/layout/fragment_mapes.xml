<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DCD9D9"
    tools:context=".FragmentMapes">


    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="wrap_content"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btProvincies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Províncies"
            android:backgroundTint="@color/blau_mapa_fosc"/>

        <Button
            android:id="@+id/btVegueries"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vegueries"
            android:backgroundTint="@color/blau_mapa_fosc"/>

        <Button
            android:id="@+id/btComarques"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comarques"
            android:backgroundTint="@color/blau_mapa_fosc"/>

        <Button
            android:id="@+id/btMunicipis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Municipis"
            android:backgroundTint="@color/blau_mapa_fosc"/>
    </LinearLayout>

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/buttonLayout"
        android:layout_marginTop="100dp" />


</FrameLayout>
