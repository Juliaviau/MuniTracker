<!-- rounded_text_background.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Color de fondo del texto -->
    <solid android:color="#F0F0F0" /> <!-- Color gris claro (ajústalo si deseas otro color) -->

    <!-- Esquinas redondeadas -->
    <corners android:radius="12dp" /> <!-- Ajusta el valor según la curvatura deseada -->

    <!-- Borde opcional -->
    <stroke
        android:width="1dp"
        android:color="#D0D0D0" /> <!-- Borde gris claro (opcional, ajústalo o elimínalo) -->
</shape>
